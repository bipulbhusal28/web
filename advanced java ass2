import java.sql.*;
public class StudentConsoleCRUDSystem {
    private static final String URL = "jdbc:mysql://localhost:3306/db_college";
    public static void main(String[] args) {
        try (Connection conn = DriverManager.getConnection(URL, "root", "password")) {
            // CREATE
            String createSQL = "INSERT INTO tbl_student (name, faculty, batch) VALUES (?, ?, ?)";
            try (PreparedStatement pstmt = conn.prepareStatement(createSQL)) {
                pstmt.setString(1, "Suresh Sharma"); pstmt.setString(2, "Computer"); pstmt.setInt(3, 2023);
                pstmt.executeUpdate();
            }
            // READ
            String readSQL = "SELECT name FROM tbl_student";
            try (PreparedStatement pstmt = conn.prepareStatement(readSQL); ResultSet rs = pstmt.executeQuery()) {
                while(rs.next()) System.out.println("Student Row Name: " + rs.getString("name"));
            }
            // UPDATE
            String updateSQL = "UPDATE tbl_student SET faculty = ? WHERE name = ?";
            try (PreparedStatement pstmt = conn.prepareStatement(updateSQL)) {
                pstmt.setString(1, "IT"); pstmt.setString(2, "Suresh Sharma");
                pstmt.executeUpdate();
            }
            // DELETE
            String deleteSQL = "DELETE FROM tbl_student WHERE name = ?";
            try (PreparedStatement pstmt = conn.prepareStatement(deleteSQL)) {
                pstmt.setString(1, "Suresh Sharma");
                pstmt.executeUpdate();
            }
        } catch (SQLException e) { e.printStackTrace(); }
    }
}
