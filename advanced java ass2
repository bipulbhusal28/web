    <h2>17. Web Cookies Generation, Tracking & Retrieval Management</h2>
    <p>A <strong>Cookie</strong> is a key-value data snippet transmitted via HTTP response headers and stored on the client machine by the browser. It is included in future headers to maintain state across independent HTTP requests.</p>
<pre>
import java.io.*;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.*;

@WebServlet("/CookieManager")
public class CookieManager extends HttpServlet {
    protected void doGet(HttpServletRequest req, HttpServletResponse res) throws IOException {
        // Create and write cookie
        Cookie tracker = new Cookie("userBranch", "ComputerScience");
        tracker.setMaxAge(60 * 60 * 24);
        res.addCookie(tracker);
        
        // Read cookies
        Cookie[] jar = req.getCookies();
        if (jar != null) {
            for (Cookie c : jar) {
                res.getWriter().println("Found Cookie: " + c.getName() + " = " + c.getValue());
            }
        }
    }
}
</pre>

